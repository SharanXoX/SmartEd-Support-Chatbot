# =============================================================================
# SmartEd Support Chatbot — Environment template
# Copy to `.env` at the repository root (and optionally `backend/.env`).
# Never commit real secrets. Rotate keys if accidentally exposed.
# =============================================================================

# --- Service URLs (deployment / integration) ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8080

# --- Primary chat LLM (default: Groq) ---
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional OpenAI (chat when AI_PROVIDER=openai; embeddings for RAG) ---
# AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Security (required in production; min 16 characters) ---
JWT_SECRET=

# --- Database ---
# Local dev default: SQLite under backend/ (set in app config if unset)
# Production / Docker:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/smarted_support

# --- Bootstrap admin (first-run only; disable in hardened production) ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# --- CORS (comma-separated browser origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080

# --- Intent → bundled support flows (0.0–1.0) ---
INTENT_FLOW_THRESHOLD=0.38

# --- Storage paths (container paths shown for Docker) ---
CHROMA_PERSIST_DIR=./vector_db/chroma_data
UPLOADS_DIR=./storage/uploads
VISUAL_ASSETS_DIR=./storage/visuals

# --- Mock LMS (disable when wired to real LMS APIs) ---
MOCK_STUDENT_ENABLED=true
# MOCK_STUDENT_PATH=

# --- Operations ---
ENABLE_DEBUG_ROUTES=false
RATE_LIMIT_DEFAULT=60/minute
SEED_DEMO_FAQS=true

# --- Optional escalation webhook ---
# ESCALATION_WEBHOOK_URL=

# --- Frontend build (Vite) — empty = same-origin proxy in dev ---
# VITE_API_URL=

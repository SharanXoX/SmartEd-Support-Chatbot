# Copy to `.env` at repo root for Docker Compose (optional local overrides).

# --- Primary chat LLM (default: Groq) ---
AI_PROVIDER=groq
GROQ_API_KEY=
# Examples: llama-3.1-70b-versatile | llama3-70b-8192 | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Switch chat provider back to OpenAI:
# AI_PROVIDER=openai
OPENAI_API_KEY=

# Required in production (min 16 chars recommended)
JWT_SECRET=replace-with-long-random-secret

# Postgres (Docker Compose defaults shown)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/smarted_support

# Bootstrap admin user on API startup if missing
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# Model configuration (OpenAI provider path + embeddings / RAG)
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Intent → bundled JSON flows under backend/flows (0–1)
INTENT_FLOW_THRESHOLD=0.38

# Paths (inside containers these map to volumes)
CHROMA_PERSIST_DIR=/data/chroma
UPLOADS_DIR=/data/uploads
VISUAL_ASSETS_DIR=/data/visuals

# Frontend origin(s)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173

# Browser-facing URL for absolute screenshot links in API responses
PUBLIC_BASE_URL=http://localhost:8080

# Debug routes: GET /debug/env and /debug/provider
ENABLE_DEBUG_ROUTES=true

# Optional escalation webhook for ticket notifications
# ESCALATION_WEBHOOK_URL=https://hooks.example.com/support

# Frontend build-time base URL when served separately (production)
# VITE_API_URL=https://support-api.example.com
